# Copy this file to .env.local and fill in real values from your Firebase project
# (Firebase Console -> Project Settings -> General -> "Your apps" -> SDK config)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Gemini API key from https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=

# Optional: a namespace for Firestore docs. Defaults to "hangouts-app".
VITE_APP_ID=hangouts-app
