# Copy this file to .env.local and fill in real values from your Firebase project
# (Firebase Console -> Project Settings -> General -> "Your apps" -> SDK config)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Gemini API key from https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=

# Optional: a namespace for Firestore docs. Defaults to "hangouts-app".
VITE_APP_ID=hangouts-app

# --- Real-events partner APIs (SERVER-SIDE — used by the /api/events proxy) ---
# These are read by the serverless function, NOT bundled into the client, so
# they have NO "VITE_" prefix. Set them in Vercel → Settings → Environment
# Variables (and here for local `vercel dev`). Each source is optional: the
# proxy queries only the providers whose key is present, and the app always
# falls back to Gemini AI search. AI search alone needs none of these.
#
# Ticketmaster Discovery (free): https://developer.ticketmaster.com/
TICKETMASTER_API_KEY=
# SeatGeek (client id + optional secret): https://seatgeek.com/account/develop
SEATGEEK_CLIENT_ID=
SEATGEEK_CLIENT_SECRET=
# PredictHQ (paid, Bearer token): https://www.predicthq.com/
PREDICTHQ_TOKEN=
# Google Places API (New) — powers "places to do when you're free"
# (restaurants/bars/activities), queried via ?kind=places. Enable "Places API
# (New)" in the same Google Cloud project as your Gemini billing; the Maps
# Platform $200/mo free credit covers a beta. Key needs Places API (New) access.
GOOGLE_PLACES_KEY=
