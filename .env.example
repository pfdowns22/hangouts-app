# Copy this file to .env.local and fill in real values from your Firebase project
# (Firebase Console -> Project Settings -> General -> "Your apps" -> SDK config)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Gemini API key from https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=

# Optional: a namespace for Firestore docs. Defaults to "hangouts-app".
VITE_APP_ID=hangouts-app

# --- Real-events partner APIs (SERVER-SIDE — used by the /api/events proxy) ---
# These are read by the serverless function, NOT bundled into the client, so
# they have NO "VITE_" prefix. Set them in Vercel → Settings → Environment
# Variables (and here for local `vercel dev`). Each source is optional: the
# proxy queries only the providers whose key is present, and the app always
# falls back to Gemini AI search. AI search alone needs none of these.
#
# Ticketmaster Discovery (free): https://developer.ticketmaster.com/
TICKETMASTER_API_KEY=
# SeatGeek (client id + optional secret): https://seatgeek.com/account/develop
SEATGEEK_CLIENT_ID=
SEATGEEK_CLIENT_SECRET=
# PredictHQ (paid, Bearer token): https://www.predicthq.com/
PREDICTHQ_TOKEN=
# Google Places API (New) — powers "places to do when you're free"
# (restaurants/bars/activities), queried via ?kind=places. Enable "Places API
# (New)" in the same Google Cloud project as your Gemini billing; the Maps
# Platform $200/mo free credit covers a beta. Key needs Places API (New) access.
GOOGLE_PLACES_KEY=

# --- Self-serve sponsored marketplace + email (SERVER-side) ---
# Stripe powers /sponsor checkout; the webhook activates the paid placement.
# Register the webhook URL https://<deploy>/api/stripe-webhook for the
# checkout.session.completed event to get the signing secret.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Firebase service-account JSON (single line) so the webhook can write the
# sponsored placement. Firebase Console → Project Settings → Service accounts →
# Generate new private key, then paste the whole JSON as this value.
FIREBASE_SERVICE_ACCOUNT=
# Resend (transactional email) for "event proposed" notifications. RESEND_FROM
# must be an address on a domain you've verified in Resend.
RESEND_API_KEY=
RESEND_FROM=

# --- Affiliate / referral (CLIENT-side, VITE_ prefixed; monetization) ---
# Wrap outbound partner links to earn referral commission. Each value is EITHER
# a deeplink template containing "{url}" (e.g. Partnerize/Impact:
# "https://prf.hn/click/camref:XXXX/destination:{url}") OR a "key=value" query
# param to append. Leave blank until you enroll — links stay unchanged.
# Ticketing (primary + resale): Ticketmaster/Live Nation, SeatGeek, StubHub, Vivid Seats
VITE_AFFILIATE_TICKETMASTER=
VITE_AFFILIATE_SEATGEEK=
VITE_AFFILIATE_STUBHUB=
VITE_AFFILIATE_VIVIDSEATS=
# Experiences / tours: Viator, GetYourGuide
VITE_AFFILIATE_VIATOR=
# Reservations: OpenTable, Resy
VITE_AFFILIATE_OPENTABLE=
# Rideshare (separate programs): Uber, Lyft
VITE_AFFILIATE_UBER=
VITE_AFFILIATE_LYFT=
# Group getaways: Booking.com, Expedia
VITE_AFFILIATE_BOOKING=

# --- Owner dashboard (CLIENT-side) ---
# Comma-separated emails allowed to view the /owner revenue dashboard. Match is
# against the signed-in account's email. Leave blank to disable for everyone.
VITE_OWNER_EMAIL=

# --- Ride partner (Uber Guest Rides / Lyft partner) — SERVER-side, optional ---
# Live ride quotes/booking require approval into a partner program (Uber & Lyft
# closed their public ride APIs). Inert until set: /api/ride-quote returns
# available:false and the app falls back to the affiliate ride deep-link.
# RIDE_PROVIDER forces a provider ('uber'|'lyft'); otherwise it's inferred.
RIDE_PROVIDER=
UBER_CLIENT_ID=
UBER_CLIENT_SECRET=
UBER_SERVER_TOKEN=
LYFT_CLIENT_ID=
LYFT_CLIENT_SECRET=

# --- AI failover (Moonshot / Kimi) — server-side only, set in Vercel --------
# When Gemini's daily budget lane is spent (or Gemini errors), /api/ai fails
# over to Moonshot automatically. Get a key at platform.moonshot.ai.
# MOONSHOT_API_KEY=
# MOONSHOT_MODEL=kimi-latest
# Budget lanes (calls/day), all optional:
# AI_GLOBAL_DAILY_CAP=1500        # Gemini lane
# AI_GLOBAL_GROUNDED_CAP=300
# AI_MOONSHOT_DAILY_CAP=4000      # Moonshot lane
# AI_MOONSHOT_GROUNDED_CAP=1500
# AI_USER_DAILY_CAP=80            # per-user, across both lanes
# AI_USER_GROUNDED_CAP=25
