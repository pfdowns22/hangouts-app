rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Profile: any authenticated user can READ another user's profile so
    // group-suggestion logic can aggregate preferences and availability.
    // Only the owner can write their own profile.
    match /artifacts/{appId}/users/{userId}/profiles/{profileDoc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Feed: a user can fully manage their own feed. Group members can
    // additionally CREATE proposal/suggestion items in each other's feeds
    // (must include groupId proving they're in the same group).
    match /artifacts/{appId}/users/{userId}/feed/{feedDoc} {
      allow read, update, delete: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && (
        request.auth.uid == userId
        ||
        (
          request.resource.data.type in ['groupProposal', 'groupSuggestion']
          && request.resource.data.data.groupId is string
          && request.auth.uid in get(/databases/$(database)/documents/artifacts/$(appId)/public/data/groups/$(request.resource.data.data.groupId)).data.members
        )
      );
    }

    // Fallback for any other per-user docs (kept private)
    match /artifacts/{appId}/users/{userId}/{coll}/{doc=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Feedback: any signed-in user can submit; no client reads (owner views via Firebase Console)
    match /artifacts/{appId}/public/data/feedback/{feedbackId} {
      allow create: if request.auth != null
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() < 5000
        && request.resource.data.userId == request.auth.uid;
    }

    // App metadata (e.g. the daily Gemini grounding counter). Any signed-in
    // user can read it and bump the counter; it holds no sensitive data.
    match /artifacts/{appId}/public/data/meta/{doc} {
      allow read, write: if request.auth != null;
    }

    // Shared event pool: a community cache of discovered events (no personal
    // data) so feeds hydrate instantly and the AI budget is spent once per
    // area rather than once per user. Signed-in users read and contribute;
    // no client deletes. Docs are content-addressed (geo|title|day), so
    // writes are idempotent merges with basic shape checks.
    match /artifacts/{appId}/public/data/eventPool/{eventId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() < 300;
    }

    // Sponsored placements: any signed-in user can read; content is authored by
    // the owner via the Firebase Console (no client create/delete). Clients may
    // only increment the aggregate impressions/clicks counters.
    match /artifacts/{appId}/public/data/sponsored/{id} {
      allow read: if request.auth != null;
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['impressions', 'clicks']);
    }

    // Legal acceptances: append-only audit log of who accepted the ToS/NDA.
    // Any signed-in user can create their own record; no client reads or
    // edits (owner views via Firebase Console). Each record must carry the
    // submitter's own uid so it can't be forged on someone else's behalf.
    match /artifacts/{appId}/public/data/legalAcceptances/{acceptId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
    }

    // Group docs: any signed-in user can read.
    // Existing members can update any field.
    // Non-members can ONLY add themselves to members[] (used by the invite-link join flow).
    match /artifacts/{appId}/public/data/groups/{groupId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow delete: if request.auth != null
        && request.auth.uid in resource.data.members;
      allow update: if request.auth != null && (
        // Existing member — full update permission
        request.auth.uid in resource.data.members
        ||
        // Non-member joining via invite: only modifies members[], and only
        // by appending their own uid (no removals, no other field changes).
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members'])
          && request.resource.data.members.hasAll(resource.data.members)
          && request.resource.data.members.hasAll([request.auth.uid])
          && !(request.auth.uid in resource.data.members)
        )
      );

      // Messages inside a group: members read; sender creates; anyone in the
      // group may toggle reactions, but only the sender can edit/delete.
      match /messages/{messageId} {
        function isMember() {
          return request.auth != null
            && request.auth.uid in get(/databases/$(database)/documents/artifacts/$(appId)/public/data/groups/$(groupId)).data.members;
        }
        allow read: if isMember();
        allow create: if isMember() && request.resource.data.senderId == request.auth.uid;
        allow update: if isMember() && (
          resource.data.senderId == request.auth.uid
          || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])
        );
        allow delete: if isMember() && resource.data.senderId == request.auth.uid;
      }

      // Proposals inside a group: any member can read & create & RSVP.
      // Only the proposer or group admin can delete.
      match /proposals/{proposalId} {
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/artifacts/$(appId)/public/data/groups/$(groupId)).data.members;
        allow create: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/artifacts/$(appId)/public/data/groups/$(groupId)).data.members
          && request.resource.data.proposerId == request.auth.uid;
        allow update: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/artifacts/$(appId)/public/data/groups/$(groupId)).data.members;
        allow delete: if request.auth != null && (
          resource.data.proposerId == request.auth.uid
          || get(/databases/$(database)/documents/artifacts/$(appId)/public/data/groups/$(groupId)).data.adminId == request.auth.uid
        );
      }

      // Shared "Plan" conversations inside a group (the Plan tab). Any member
      // can read, start (createdBy must be self), and update (e.g. title /
      // lastMessageAt). Only the creator or the group admin can delete.
      // Personal plans live under users/{userId}/plans and are already covered
      // by the per-user catch-all rule above — no entry needed here.
      match /plans/{planId} {
        function isPlanMember() {
          return request.auth != null
            && request.auth.uid in get(/databases/$(database)/documents/artifacts/$(appId)/public/data/groups/$(groupId)).data.members;
        }
        allow read: if isPlanMember();
        allow create: if isPlanMember() && request.resource.data.createdBy == request.auth.uid;
        allow update: if isPlanMember();
        allow delete: if isPlanMember() && (
          resource.data.createdBy == request.auth.uid
          || get(/databases/$(database)/documents/artifacts/$(appId)/public/data/groups/$(groupId)).data.adminId == request.auth.uid
        );

        // Messages within a group plan: members read; a member may create
        // their own message (senderId == uid) OR an assistant message
        // (role == 'assistant', written by the member's client after the AI
        // turn). Members may edit/delete within their shared plan.
        match /messages/{messageId} {
          allow read: if isPlanMember();
          allow create: if isPlanMember() && (
            request.resource.data.senderId == request.auth.uid
            || request.resource.data.role == 'assistant'
          );
          allow update, delete: if isPlanMember();
        }
      }
    }
  }
}
